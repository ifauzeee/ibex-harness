# =============================================================================
# IBEX Proxy Service — Environment Variables
# Copy to .env: cp services/proxy/.env.example services/proxy/.env
# Full registry: docs/ENVIRONMENT_VARIABLES.md §9
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────────

# Redis URL (rate limiting; required when limiter is enabled)
REDIS_URL=

# gRPC address of auth service (host:port)
IBEX_AUTH_GRPC_ADDR=127.0.0.1:9091

# ── Optional ─────────────────────────────────────────────────────────────────

IBEX_ENV=development
IBEX_SERVICE_NAME=proxy

# HTTP listen port (default: 8080)
IBEX_PORT=8080

IBEX_SHUTDOWN_TIMEOUT=30s

# per-call auth ValidateToken deadline (default: 50ms)
IBEX_AUTH_VALIDATE_TIMEOUT=50ms

# max chat request body bytes (default: 1048576)
IBEX_MAX_REQUEST_BODY_BYTES=1048576

IBEX_REQUEST_ID_HEADER=X-Request-ID
IBEX_TRACE_ID_HEADER=X-Trace-ID

# default org rate limit RPM (default: 60)
IBEX_RATE_LIMIT_DEFAULT_RPM=60

# comma-separated org_uuid=rpm overrides
IBEX_RATE_LIMIT_ORG_OVERRIDES=

# optional base URL for error envelope docs_url
IBEX_ERROR_DOCS_BASE=

# ── Observability ────────────────────────────────────────────────────────────

OTEL_SERVICE_NAME=ibex-proxy
OTEL_SERVICE_VERSION=dev
OTEL_DEPLOYMENT_ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SAMPLE_RATIO=1.0

# ── Development convenience ──────────────────────────────────────────────────

IBEX_LOG_LEVEL=debug

# Smoke test script only (not read by proxy binary):
# IBEX_PROXY_ADDR=http://localhost:8080
# IBEX_DEV_TOKEN=ibex_pat_00000000-0000-0000-0000-000000000004_LOCALDEVELOPMENTONLY
# IBEX_DEV_AGENT_ID=00000000-0000-0000-0000-000000000003
# IBEX_DEV_ORG_ID=00000000-0000-0000-0000-000000000001
