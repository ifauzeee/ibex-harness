# =============================================================================
# IBEX Auth Service — Environment Variables
# Copy to .env: cp services/auth/.env.example services/auth/.env
# Full registry: docs/ENVIRONMENT_VARIABLES.md §10
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL DSN (lib/pq format)
POSTGRES_DSN=

# ── Optional ─────────────────────────────────────────────────────────────────

# deployment profile: development | staging | production (default: development)
IBEX_ENV=development

# logical service name for logs and metrics (default: auth)
IBEX_SERVICE_NAME=auth

# HTTP listen port for /health, /ready, /metrics (default: 8081)
IBEX_PORT=8081

# gRPC listen port for AuthService (default: 9091)
IBEX_GRPC_PORT=9091

# graceful shutdown drain timeout (default: 30s)
IBEX_SHUTDOWN_TIMEOUT=30s

# Argon2id parameters for PAT hashing (defaults match ADR-0010 production profile)
IBEX_ARGON2_MEMORY_KIB=65536
IBEX_ARGON2_TIME=3
IBEX_ARGON2_PARALLELISM=4

# ── Observability ────────────────────────────────────────────────────────────

OTEL_SERVICE_NAME=ibex-auth
OTEL_SERVICE_VERSION=dev
OTEL_DEPLOYMENT_ENVIRONMENT=development
# leave empty to disable OTLP export in local dev
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SAMPLE_RATIO=1.0

# ── Development convenience ──────────────────────────────────────────────────

# DEBUG | INFO | WARN | ERROR (default: INFO)
IBEX_LOG_LEVEL=debug
