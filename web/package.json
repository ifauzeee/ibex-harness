{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "generate:changelog": "node scripts/generate-changelog-content.mjs",
    "predev": "node scripts/generate-changelog-content.mjs",
    "pretypecheck": "node scripts/generate-changelog-content.mjs",
    "pretest": "node scripts/generate-changelog-content.mjs",
    "dev": "node scripts/run-dev.mjs",
    "dev:clean": "node scripts/stop-next.mjs && node scripts/clean-next.mjs && node scripts/run-dev.mjs",
    "dev:webpack": "node scripts/run-dev.mjs --webpack",
    "dev:turbo": "node scripts/run-dev.mjs --turbopack",
    "prebuild": "node scripts/ensure-solo-build.mjs && node scripts/generate-changelog-content.mjs",
    "build": "node scripts/ensure-solo-build.mjs && node scripts/build-hint.mjs && node scripts/next-build.mjs",
    "build:fast": "node scripts/ensure-solo-build.mjs && node scripts/build-hint.mjs && node scripts/next-build.mjs --no-cache",
    "build:clean": "node scripts/stop-next.mjs && node scripts/clean-next.mjs && node scripts/ensure-solo-build.mjs && node scripts/build-hint.mjs && node scripts/next-build.mjs",
    "stop:next": "node scripts/stop-next.mjs",
    "prestart": "node scripts/prestart.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "deploy:pages": "wrangler pages deploy out --project-name=ibex-harness-docs --branch=main --commit-dirty=true",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.17",
    "@radix-ui/react-tabs": "^1.1.2",
    "beautiful-mermaid": "^1.1.3",
    "d3": "^7.9.0",
    "fumadocs-core": "^14.0.0",
    "fumadocs-mdx": "^11.0.0",
    "fumadocs-ui": "^14.0.0",
    "geist": "^1.3.0",
    "lucide-react": "^1.24.0",
    "mermaid": "^11.16.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^1.22.0",
    "swr": "^2.3.3",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.0",
    "@tailwindcss/postcss": "^4.3.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
