{
  "name": "docs",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node scripts/stop-next.mjs && node scripts/clean-next.mjs && next dev",
    "dev:turbo": "next dev --turbo",
    "prebuild": "node scripts/ensure-solo-build.mjs",
    "build": "node scripts/ensure-solo-build.mjs && node scripts/build-hint.mjs && node scripts/next-build.mjs",
    "build:fast": "node scripts/ensure-solo-build.mjs && node scripts/build-hint.mjs && node scripts/next-build.mjs --no-cache",
    "build:clean": "node scripts/stop-next.mjs && node scripts/clean-next.mjs && node scripts/ensure-solo-build.mjs && node scripts/build-hint.mjs && node scripts/next-build.mjs",
    "stop:next": "node scripts/stop-next.mjs",
    "prestart": "node scripts/prestart.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:pages": "wrangler pages deploy out --project-name=ibex-harness-docs --branch=main --commit-dirty=true",
    "deploy:pages:local": "node scripts/deploy-pages-local.mjs",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.2",
    "beautiful-mermaid": "^1.1.3",
    "fumadocs-core": "^14.0.0",
    "fumadocs-mdx": "^11.0.0",
    "fumadocs-ui": "^14.0.0",
    "geist": "^1.3.0",
    "lucide-react": "^0.460.0",
    "mermaid": "^11.15.0",
    "next": "^15.0.0",
    "next-themes": "^0.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^1.22.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.24.0"
  }
}
