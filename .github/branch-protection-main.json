{
  "required_status_checks": {
    "strict": true,
    "checks": [
      { "context": "repo-guards" },
      { "context": "markdownlint" },
      { "context": "gitleaks" },
      { "context": "CodeQL" },
      { "context": "trivy" },
      { "context": "osv-scan / osv-scan" },
      { "context": "semgrep" },
      { "context": "golangci-lint" },
      { "context": "security-integration" },
      { "context": "go-race" },
      { "context": "go-services (auth)" },
      { "context": "go-services (proxy)" },
      { "context": "proxy-auth-smoke" },
      { "context": "bandit" },
      { "context": "hadolint" },
      { "context": "coverage" },
      { "context": "go-mod-tidy" },
      { "context": "shellcheck" },
      { "context": "dependency-review" },
      { "context": "buf-lint" },
      { "context": "proto-contract" },
      { "context": "db-migrate-smoke" },
      { "context": "auth-validate-smoke" },
      { "context": "proxy-agent-verify-smoke" },
      { "context": "compose-validate" },
      { "context": "govulncheck" },
      { "context": "semantic-pr-title" },
      { "context": "license-check" }
    ]
  },
  "enforce_admins": true,
  "required_pull_request_reviews": {
    "dismiss_stale_reviews": false,
    "require_code_owner_reviews": false,
    "required_approving_review_count": 0
  },
  "restrictions": null,
  "required_linear_history": false,
  "allow_force_pushes": false,
  "allow_deletions": false,
  "block_creations": false,
  "required_conversation_resolution": true,
  "lock_branch": false,
  "allow_fork_syncing": false
}
