{
  "name": "ibex-harness",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "web:dev": "turbo dev --filter=web",
    "web:dev:clean": "pnpm --filter web dev:clean",
    "web:build": "turbo build --filter=web",
    "web:build:clean": "pnpm --filter web build:clean",
    "web:start": "pnpm --filter web start",
    "docs:dev": "pnpm web:dev",
    "docs:dev:clean": "pnpm web:dev:clean",
    "docs:build": "pnpm web:build",
    "docs:build:clean": "pnpm web:build:clean",
    "docs:start": "pnpm web:start"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "pnpm": {
    "overrides": {
      "dompurify": ">=3.4.11",
      "esbuild": ">=0.28.1",
      "postcss": ">=8.5.10"
    }
  }
}
