# IBEX Harness — local dev compose (infra/compose/dev)
# Copy to .env for overrides: cp .env.example .env
# Do not commit .env with production secrets.

POSTGRES_USER=ibex
POSTGRES_PASSWORD=ibex
POSTGRES_DB=ibex
POSTGRES_PORT=5432

REDIS_PORT=6379

CLICKHOUSE_DB=ibex
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_HTTP_PORT=8123
# Host port for ClickHouse native protocol (container listens on 9000; avoids clash with MinIO API on 9000)
CLICKHOUSE_NATIVE_HOST_PORT=9002

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Application DSNs (for services; not used by compose itself)
REDIS_URL=redis://localhost:6379/0
POSTGRES_DSN=postgresql+asyncpg://ibex:ibex@localhost:5432/ibex
CLICKHOUSE_DSN=clickhouse://default:@localhost:8123/ibex
S3_ENDPOINT=http://localhost:9000
S3_BUCKET_SESSIONS=ibex-sessions
S3_BUCKET_EXPORTS=ibex-exports
